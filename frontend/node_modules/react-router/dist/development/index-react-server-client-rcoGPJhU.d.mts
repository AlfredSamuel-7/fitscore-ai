// src/contexts/AuthContext.tsx
import React, { createContext, useContext, useEffect, useState, ReactNode } from 'react'
import axios from 'axios'
import { useNavigate } from 'react-router-dom'

type User = {
    id?: number
    name?: string
    email?: string
}

type AuthContextValue = {
    user: User | null
    token: string | null
    loading: boolean
    signin: (email: string, password: string) => Promise<void>
    signup: (name: string, email: string, password: string) => Promise<void>
    signout: () => void
    refreshProfile: () => Promise<void>
}

const AuthContext = createContext<AuthContextValue | undefined>(undefined)

export function AuthProvider({ children }: { children: ReactNode }) {
    const [user, setUser] = useState<User | null>(null)
    const [token, setToken] = useState<string | null>(null)
    const [loading, setLoading] = useState<boolean>(true)
    const nav = useNavigate()

    useEffect(() => {
        const t = localStorage.getItem('token')
        if (t) {
            setToken(t)
            // try to fetch profile
            axios.get('/api/profile', { headers: { Authorization: `Bearer ${t}` } })
                .then(r => {
                    // if profile endpoint returns user info, set it; else keep token only
                    if (r.data && (r.data.name || r.data.skills)) {
                        // r.data could be the profile (not the user) — keep it simple
                        setUser({ name: r.data.name || 'User' })
                    }
                })
                .catch(() => {
                    localStorage.removeItem('token')
                    setToken(null)
                    setUser(null)
                })
                .finally(() => setLoading(false))
        } else {
            setLoading(false)
        }
    }, [])

    const signin = async (email: string, password: string) => {
        setLoading(true)
        try {
            const res = await axios.post('/api/signin', { email, password })
            const t = res.data.token
            localStorage.setItem('token', t)
            setToken(t)
            setUser(res.data.user || null)
            nav('/dashboard')
        } catch (err) {
            setLoading(false)
            throw err
        } finally {
            setLoading(false)
        }
    }

    const signup = async (name: string, email: string, password: string) => {
        setLoading(true)
        try {
            const res = await axios.post('/api/signup', { name, email, password })
            const t = res.data.token
            localStorage.setItem('token', t)
            setToken(t)
            setUser(res.data.user || null)
            nav('/dashboard')
        } catch (err) {
            setLoading(false)
            throw err
        } finally {
            setLoading(false)
        }
    }

    const signout = () => {
        localStorage.removeItem('token')
        setToken(null)
        setUser(null)
        nav('/')
    }

    const refreshProfile = async () => {
        if (!token) return
        try {
            const res = await axios.get('/api/profile', { headers: { Authorization: `Bearer ${token}` } })
            if (res.data) setUser(prev => ({ ...(prev || {}), name: res.data.name || prev?.name }))
        } catch {
            // ignore
        }
    }

    return (
        <AuthContext.Provider value= {{ user, token, loading, signin, signup, signout, refreshProfile }
}>
    { children }
    </AuthContext.Provider>
  )
}

export function useAuth() {
    const ctx = useContext(AuthContext)
    if (!ctx) throw new Error('useAuth must be used within AuthProvider')
    return ctx
}

